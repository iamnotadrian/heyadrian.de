---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  guiltyCategories,
  guiltyFrequencies,
} from "../lib/guiltyCalculatorUtils";
---

<BaseLayout
  title="Guilty-Rechner | iam(not)adrian"
  description="Berechne neutral und einfach, wie viel Geld oder Zeit bei wiederkehrenden Gewohnheiten über Zeit zusammenkommt."
  currentPath="/guilty-rechner/"
  lang="de"
>
  <section class="intro guilty-intro">
    <p>
      <span class="mark">Was kostet dich</span> diese Gewohnheit wirklich?
    </p>

    <p>
      Berechne neutral, wie viel Geld oder Zeit über Zeit zusammenkommt. Ohne
      Bewertung, einfach als klarer Blick auf wiederkehrende Routinen.
    </p>
  </section>

  <section class="guilty-calculator" aria-labelledby="guilty-title">
    <h2 id="guilty-title" class="stuff-title">Guilty-Rechner</h2>

    <form class="guilty-form" data-guilty-form novalidate>
      <label class="guilty-field">
        <span>Kategorie</span>
        <select name="category" data-guilty-category>
          {
            guiltyCategories.map((category) => (
              <option value={category.value} data-category-type={category.type}>
                {category.label}
              </option>
            ))
          }
        </select>
      </label>

      <div class="guilty-fieldset" aria-label="Dauer der Gewohnheit">
        <label class="guilty-field">
          <span>Jahre</span>
          <input
            name="years"
            type="number"
            min="0"
            step="1"
            inputmode="numeric"
            value="10"
            data-guilty-years
          />
        </label>

        <label class="guilty-field">
          <span>Monate</span>
          <input
            name="months"
            type="number"
            min="0"
            max="11"
            step="1"
            inputmode="numeric"
            value="0"
            data-guilty-months
          />
        </label>
      </div>

      <div class="guilty-fieldset" data-money-fields aria-label="Ausgaben">
        <label class="guilty-field">
          <span data-money-label>Betrag</span>
          <input
            name="amount"
            type="number"
            min="0"
            step="0.01"
            inputmode="decimal"
            value="30"
            data-guilty-amount
          />
        </label>

        <label class="guilty-field" data-frequency-field>
          <span>Häufigkeit</span>
          <select name="frequency" data-guilty-frequency>
            {
              guiltyFrequencies.map((frequency) => (
                <option value={frequency.value} selected={frequency.value === "month"}>
                  {frequency.label}
                </option>
              ))
            }
          </select>
        </label>
      </div>

      <label class="guilty-field" data-time-fields>
        <span>Stunden pro Tag</span>
        <input
          name="hours"
          type="number"
          min="0"
          max="24"
          step="0.25"
          inputmode="decimal"
          value="2"
          data-guilty-hours
        />
      </label>

      <p class="guilty-error" data-guilty-error hidden>
        Bitte gib eine Dauer größer als 0 und positive Werte für die sichtbaren
        Felder ein.
      </p>
    </form>

    <section class="guilty-results" aria-live="polite" data-guilty-results>
      <div class="guilty-results__header">
        <h2 data-guilty-result-title>Deine geschätzten Kosten</h2>
        <p data-guilty-summary>
          Für Rauchen über 10 Jahre bei 30,00&nbsp;€ pro Monat.
        </p>
      </div>

      <div class="guilty-key-grid" data-guilty-key-grid></div>

      <figure class="guilty-chart" aria-labelledby="guilty-chart-title">
        <figcaption id="guilty-chart-title" data-guilty-chart-title>
          Kosten über Zeit
        </figcaption>
        <svg
          viewBox="0 0 420 210"
          role="img"
          aria-describedby="guilty-chart-description"
          data-guilty-chart
        >
          <desc id="guilty-chart-description">
            Balkendiagramm der berechneten Werte je Zeitraum.
          </desc>
        </svg>
      </figure>
    </section>
  </section>

  <script>
    import {
      calculateGuiltyResult,
      getGuiltyCategoryByValue,
      guiltyFrequencies,
      type GuiltyCalculatorInput,
      type GuiltyCategory,
      type GuiltyCategoryType,
      type GuiltyChartPeriod,
      type GuiltyFrequency,
    } from "../lib/guiltyCalculatorUtils";

    const form = document.querySelector("[data-guilty-form]");
    const results = document.querySelector("[data-guilty-results]");
    const error = document.querySelector("[data-guilty-error]");
    const chart = document.querySelector("[data-guilty-chart]");
    const summary = document.querySelector("[data-guilty-summary]");
    const resultTitle = document.querySelector("[data-guilty-result-title]");
    const chartTitle = document.querySelector("[data-guilty-chart-title]");
    const keyGrid = document.querySelector("[data-guilty-key-grid]");
    const moneyFields = document.querySelector<HTMLElement>("[data-money-fields]");
    const timeFields = document.querySelector<HTMLElement>("[data-time-fields]");
    const frequencyField = document.querySelector<HTMLElement>("[data-frequency-field]");
    const moneyLabel = document.querySelector("[data-money-label]");

    const fields = {
      category: document.querySelector<HTMLSelectElement>("[data-guilty-category]"),
      years: document.querySelector<HTMLInputElement>("[data-guilty-years]"),
      months: document.querySelector<HTMLInputElement>("[data-guilty-months]"),
      amount: document.querySelector<HTMLInputElement>("[data-guilty-amount]"),
      frequency: document.querySelector<HTMLSelectElement>("[data-guilty-frequency]"),
      hours: document.querySelector<HTMLInputElement>("[data-guilty-hours]"),
    };

    const currencyFormatter = new Intl.NumberFormat("de-DE", {
      style: "currency",
      currency: "EUR",
      maximumFractionDigits: 2,
    });

    const compactCurrencyFormatter = new Intl.NumberFormat("de-DE", {
      style: "currency",
      currency: "EUR",
      notation: "compact",
      maximumFractionDigits: 1,
    });

    const numberFormatter = new Intl.NumberFormat("de-DE", {
      maximumFractionDigits: 1,
    });

    const compactNumberFormatter = new Intl.NumberFormat("de-DE", {
      notation: "compact",
      maximumFractionDigits: 1,
    });

    const getNumberValue = (input: HTMLInputElement | null) => {
      const value = Number(input?.value ?? 0);
      return Number.isFinite(value) ? Math.max(0, value) : 0;
    };

    const setText = (element: Element | null, text: string) => {
      if (element) {
        element.textContent = text;
      }
    };

    const formatDuration = (durationMonths: number) => {
      const years = Math.floor(durationMonths / 12);
      const months = durationMonths % 12;
      return [
        years ? `${years} ${years === 1 ? "Jahr" : "Jahre"}` : "",
        months ? `${months} ${months === 1 ? "Monat" : "Monate"}` : "",
      ]
        .filter(Boolean)
        .join(" und ");
    };

    const formatHours = (hours: number) => `${numberFormatter.format(hours)} h`;
    const formatCompactHours = (hours: number) =>
      `${compactNumberFormatter.format(hours)} h`;

    const renderKeyCards = (
      cards: Array<{ label: string; value: string; accent?: boolean }>,
    ) => {
      if (!keyGrid) {
        return;
      }

      keyGrid.innerHTML = cards
        .map(
          (card) => `
            <article class="guilty-key-card${card.accent ? " guilty-key-card--accent" : ""}">
              <span>${card.label}</span>
              <strong>${card.value}</strong>
            </article>
          `,
        )
        .join("");
    };

    const renderChart = (
      periods: GuiltyChartPeriod[],
      valueType: "money" | "time",
    ) => {
      if (!chart) {
        return;
      }

      const chartWidth = 420;
      const chartHeight = 210;
      const bottom = 34;
      const top = 30;
      const left = 8;
      const maxBarHeight = chartHeight - bottom - top;
      const maxAmount = Math.max(...periods.map((period) => period.value), 1);
      const gap = 7;
      const barWidth =
        (chartWidth - left * 2 - gap * Math.max(periods.length - 1, 0)) /
        Math.max(periods.length, 1);
      const formatValue =
        valueType === "money" ? compactCurrencyFormatter.format : formatCompactHours;

      chart.innerHTML = `
        <line x1="${left}" y1="${chartHeight - bottom}" x2="${chartWidth - left}" y2="${chartHeight - bottom}" class="guilty-chart__axis" />
        ${periods
          .map((period, index) => {
            const height = Math.max((period.value / maxAmount) * maxBarHeight, 3);
            const x = left + index * (barWidth + gap);
            const y = chartHeight - bottom - height;

            return `
              <g>
                <text class="guilty-chart__value" x="${x + barWidth / 2}" y="${Math.max(y - 7, 10)}" text-anchor="middle">${formatValue(period.value)}</text>
                <rect class="guilty-chart__bar" x="${x}" y="${y}" width="${barWidth}" height="${height}" rx="3"></rect>
                <text class="guilty-chart__label" x="${x + barWidth / 2}" y="${chartHeight - 12}" text-anchor="middle">${period.label}</text>
              </g>
            `;
          })
          .join("")}
      `;
    };

    const updateVisibleFields = (categoryType: GuiltyCategoryType) => {
      const usesMoney = categoryType === "money" || categoryType === "hybrid";
      const usesTime = categoryType === "time" || categoryType === "hybrid";
      const usesFrequency = categoryType === "money";

      moneyFields?.toggleAttribute("hidden", !usesMoney);
      timeFields?.toggleAttribute("hidden", !usesTime);
      frequencyField?.toggleAttribute("hidden", !usesFrequency);
      setText(moneyLabel, categoryType === "hybrid" ? "Monatliche Kosten" : "Betrag");

      fields.amount?.toggleAttribute("required", usesMoney);
      fields.hours?.toggleAttribute("required", usesTime);
    };

    const getInput = (): GuiltyCalculatorInput | null => {
      if (
        !fields.category ||
        !fields.years ||
        !fields.months ||
        !fields.amount ||
        !fields.frequency ||
        !fields.hours
      ) {
        return null;
      }

      const selectedCategory = getGuiltyCategoryByValue(fields.category.value);
      if (!selectedCategory) {
        return null;
      }

      const years = Math.floor(getNumberValue(fields.years));
      const months = Math.min(Math.floor(getNumberValue(fields.months)), 11);
      const amount = getNumberValue(fields.amount);
      const hoursPerDay = Math.min(getNumberValue(fields.hours), 24);

      fields.years.value = String(years);
      fields.months.value = String(months);
      fields.hours.value = String(hoursPerDay);

      if (selectedCategory.type === "money") {
        return {
          category: selectedCategory.value as GuiltyCategory,
          categoryType: "money",
          years,
          months,
          amount,
          frequency: fields.frequency.value as GuiltyFrequency,
        };
      }

      if (selectedCategory.type === "time") {
        return {
          category: selectedCategory.value as GuiltyCategory,
          categoryType: "time",
          years,
          months,
          hoursPerDay,
        };
      }

      return {
        category: selectedCategory.value as GuiltyCategory,
        categoryType: "hybrid",
        years,
        months,
        monthlyCost: amount,
        hoursPerDay,
      };
    };

    const updateCalculator = () => {
      if (!fields.category) {
        return;
      }

      const selectedCategory = getGuiltyCategoryByValue(fields.category.value);
      if (!selectedCategory) {
        return;
      }

      updateVisibleFields(selectedCategory.type);

      const input = getInput();
      const result = input ? calculateGuiltyResult(input) : null;
      const hasResult = Boolean(result);
      error?.toggleAttribute("hidden", hasResult);
      results?.toggleAttribute("hidden", !hasResult);

      if (!result || !input) {
        return;
      }

      const durationLabel = formatDuration(result.durationMonths);

      if (result.categoryType === "money") {
        const selectedFrequency = guiltyFrequencies.find(
          (item) => item.value === input.frequency,
        );

        setText(resultTitle, "Deine geschätzten Kosten");
        setText(chartTitle, "Kosten über Zeit");
        setText(
          summary,
          `Für ${selectedCategory.label} über ${durationLabel} bei ${currencyFormatter.format(input.amount)} ${selectedFrequency?.label ?? ""}.`,
        );
        renderKeyCards([
          { label: "Pro Monat", value: currencyFormatter.format(result.monthlyCost) },
          { label: "Pro Jahr", value: currencyFormatter.format(result.yearlyCost) },
          {
            label: "Gesamtdauer",
            value: currencyFormatter.format(result.totalCost),
            accent: true,
          },
        ]);
        renderChart(result.periods, "money");
        return;
      }

      if (result.categoryType === "time") {
        setText(resultTitle, "Deine geschätzte Zeit");
        setText(chartTitle, "Zeit über Zeit");
        setText(
          summary,
          `Für ${selectedCategory.label} über ${durationLabel} bei ${numberFormatter.format(input.hoursPerDay)} Stunden pro Tag.`,
        );
        renderKeyCards([
          { label: "Pro Tag", value: formatHours(result.hoursPerDay) },
          { label: "In Tagen", value: `${numberFormatter.format(result.totalDays)} Tage` },
          { label: "In Wochen", value: `${numberFormatter.format(result.totalWeeks)} Wochen` },
          {
            label: "Gesamtdauer",
            value: formatHours(result.totalHours),
            accent: true,
          },
        ]);
        renderChart(result.periods, "time");
        return;
      }

      setText(resultTitle, "Deine geschätzten Kosten und Zeit");
      setText(chartTitle, "Kosten über Zeit");
      setText(
        summary,
        `Für ${selectedCategory.label} über ${durationLabel} bei ${currencyFormatter.format(input.monthlyCost)} pro Monat und ${numberFormatter.format(input.hoursPerDay)} Stunden pro Tag.`,
      );
      renderKeyCards([
        { label: "Pro Monat", value: currencyFormatter.format(result.monthlyCost) },
        { label: "Pro Jahr", value: currencyFormatter.format(result.yearlyCost) },
        { label: "Zeit gesamt", value: formatHours(result.totalHours) },
        {
          label: "Kosten gesamt",
          value: currencyFormatter.format(result.totalCost),
          accent: true,
        },
      ]);
      renderChart(result.periods, "money");
    };

    form?.addEventListener("input", updateCalculator);
    form?.addEventListener("change", updateCalculator);
    updateCalculator();
  </script>
</BaseLayout>
