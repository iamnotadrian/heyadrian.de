---
interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
];

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header>
  <div>
    <h1><a class="site-title" href="/">hey i am adrian</a></h1>
    <p class="updated">Updated June 2026</p>
  </div>

  <nav class="site-nav" aria-label="Main navigation">
    {
      links.map((link) => (
        <a
          class:list={["site-nav__link", { "is-active": isActive(link.href) }]}
          href={link.href}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
